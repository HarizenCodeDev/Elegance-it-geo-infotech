# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
FRONTEND_URL=http://localhost:8081

# Database
# For local dev with PostgreSQL:
DATABASE_URL=postgresql://user:password@localhost:5432/elegance_ems
# For SQLite (development): set NODE_ENV=development and leave DATABASE_URL unset

# Authentication
JWT_SECRET=your_random_secret_key_here_min_32_chars
JWT_EXPIRES_IN=7d

# Optional: Redis (caching, session management)
REDIS_URL=

# Optional: Sentry (error tracking)
SENTRY_DSN=

# Optional: HTTPS
USE_HTTPS=false
SSL_CERT_PATH=./ssl/server.crt
SSL_KEY_PATH=./ssl/server.key

# Default admin credentials (used by seed script)
DEFAULT_EMAIL=admin@elegance.com
DEFAULT_PASSWORD=admin123
DEFAULT_NAME=Admin
