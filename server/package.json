{
  "name": "elegance-server",
  "version": "1.0.0",
  "description": "Elegance Employee Management System - Backend",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "db:migrate": "knex migrate:latest --knexfile knexfile.js",
    "db:seed": "node seeds/seed.js",
    "db:rollback": "knex migrate:rollback --knexfile knexfile.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --detectOpenHandles --forceExit",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --detectOpenHandles --forceExit",
    "test:e2e": "node tests/e2e.test.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "@sentry/node": "^7.120.4",
    "@supabase/supabase-js": "^2.100.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.2.6",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.3",
    "redis": "^4.6.13",
    "socket.io": "^4.7.4",
    "speakeasy": "^2.0.0",
    "validator": "^13.11.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "moduleFileExtensions": [
      "js",
      "json"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "controller/**/*.js",
      "middleware/**/*.js",
      "utils/**/*.js",
      "!node_modules/**"
    ]
  }
}
